 <div class="modal-overlay" id="modal-overlay" onclick="closeModals()"></div>

    <div class="modal card" id="delete-modal">
        <h3>Підтвердження</h3>
        <p>Ви дійсно хочете видалити цей номер? Цю дію неможливо скасувати.</p>
        <div class="modal-actions">
            <button class="cta-secondary" onclick="closeModals()">Скасувати</button>

            <form id="delete-form" th:action="@{/rooms/__ID__}" method="post">
                <button type="submit" class="cta-danger">Видалити</button>
            </form>
        </div>
    </div>

    <div class="modal card form-card" id="edit-modal">
        <h2>Редагувати номер</h2>

        <form id="edit-form" th:action="@{/rooms/__ID__}" method="post">

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <label>Тип
                    <select id="edit-type" name="type" required>
                        <option value="Стандарт">Стандартний номер</option>
                        <option value="Покращений стандарт">Покращений стандарт</option>
                        <option value="Напівлюкс">Напівлюкс</option>
                        <option value="Люкс">Люкс</option>
                        <option value="Президентський люкс">Президентський люкс</option>
                    </select>
                </label>
                <label>Місткість (гостей)
                    <input id="edit-guest_capacity" type="number" name="guestCapacity" step="1" required>
                </label>
            </div>

            <label>Ціна (UAH/ніч)
                <input id="edit-price" type="number" name="price" step="0.01" required>
            </label>

            <label>Опис
                <textarea id="edit-description" name="description" required></textarea>
            </label>

            <label>Зручності</label>
            <div id="edit-facilities-container" style="display: flex; flex-direction: column;">
                <!-- Можна робити th:each для набору зручностей -->
            </div>

            <div class="modal-actions" style="margin-top: 20px;">
                <button type="button" class="cta-secondary" onclick="closeModals()">Скасувати</button>
                <button type="submit" class="cta">Редагувати</button>
            </div>
        </form>
    </div>

    <main class="container">
        <div class="spacer"></div>

        <section class="card form-card" th:if="${isAdmin}">
            <h2>Додати новий номер</h2>

            <form th:action="@{/rooms}" method="post" enctype="multipart/form-data">
                <div style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 12px;">
                    <label>Назва
                        <input type="text" name="name" placeholder="Номер" required>
                    </label>
                    <label>Тип
                        <select name="type" required>
                            <option value="" disabled selected>Оберіть тип номера</option>
                            <option value="Стандарт">Стандартний номер</option>
                            <option value="Покращений стандарт">Покращений стандарт</option>
                            <option value="Напівлюкс">Напівлюкс</option>
                            <option value="Люкс">Люкс</option>
                            <option value="Президентський люкс">Президентський люкс</option>
                        </select>
                    </label>
                    <label>Ціна (UAH/ніч)
                        <input type="number" name="price" step="0.01" placeholder="1500" required>
                    </label>
                    <label>Місткість (гостей)
                        <input type="number" name="guestCapacity" step="1" placeholder="2" required>
                    </label>
                </div>

                <label>Фізичні номери (через кому)
                    <input type="text" name="roomNumbers" placeholder="Напр., 101, 102, 201A" required>
                </label>

                <label>Опис
                    <textarea name="description" placeholder="Короткий опис номера..." required></textarea>
                </label>

                <label>Зручності</label>
                <div id="facilities-container" style="display: flex; flex-direction: column;">
                    <!-- Можна вставити th:each для всіх можливих зручностей -->
                    <!--
                <label th:each="facility : ${allFacilities}">
                    <input type="checkbox" th:value="${facility}" th:text="${facility}"/>
                </label>
                -->
                </div>

                <label>Зображення (можна обрати декілька)
                    <input type="file" name="images" multiple required>
                </label>

                <button type="submit" class="cta" style="margin-top: 12px;">Додати номер</button>
            </form>
        </section>
    </main>